---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import LucideIcon from "../components/LucideIcon.astro";

const lang = "fr";
---

<Layout
  title="Page introuvable - Pachatopia"
  description="La page demandee est introuvable. Retrouvez les principales portes d'entree du projet Pachatopia."
  lang={lang}
  noindex={true}
  type="website"
  image="/images/community.jpg"
  ogImageAlt="Page introuvable de Pachatopia"
>
  <Header lang={lang} />
  <main>
    <section class="relative isolate overflow-hidden py-24 text-white md:py-32">
      <div class="absolute inset-0">
        <img src="/images/community.jpg" alt="" class="h-full w-full object-cover" aria-hidden="true" />
        <div class="absolute inset-0 bg-[linear-gradient(135deg,rgba(14,39,35,0.92),rgba(10,91,75,0.78))]"></div>
      </div>
      <div class="absolute inset-0 -z-0 overflow-hidden" aria-hidden="true">
        <div class="absolute left-[10%] top-12 h-44 w-44 rounded-full bg-white/8 blur-3xl"></div>
        <div class="absolute bottom-0 right-[12%] h-72 w-72 rounded-full bg-golden/15 blur-3xl"></div>
      </div>
      <div class="site-container relative z-10">
        <div class="site-container-compact px-0 text-center">
          <div class="section-kicker mx-auto mb-6 w-fit border-white/15 bg-white/10 text-white shadow-none">
            <LucideIcon name="SearchX" class="h-4 w-4 text-golden" />
            Erreur 404
          </div>
          <h1 class="text-4xl font-heading font-bold tracking-tight md:text-5xl lg:text-6xl">Cette page n'existe pas, ou plus.</h1>
          <p class="mx-auto mt-6 max-w-2xl text-lg leading-8 text-white/85 md:text-xl">Vous pouvez revenir a l'accueil, reprendre le fil du projet, ou nous contacter directement si vous cherchiez une information precise.</p>
        </div>
      </div>
      <svg class="absolute bottom-0 left-0 w-full" viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
        <path d="M0 40C240 80 480 0 720 40C960 80 1200 0 1440 40V80H0V40Z" fill="white"></path>
      </svg>
    </section>

    <section class="bg-white py-20 md:py-28">
      <div class="site-container">
        <div class="grid grid-cols-1 gap-12 lg:grid-cols-[0.9fr_1.1fr] lg:items-start lg:gap-16">
          <div>
            <div class="section-kicker w-fit border-primary/10 bg-primary/[0.03] shadow-none">
              <LucideIcon name="Compass" class="h-4 w-4 text-accent" />
              Repartir du bon endroit
            </div>
            <h2 class="mt-6 text-3xl font-heading font-bold tracking-tight text-primary md:text-4xl">Les pages les plus utiles pour vous reorienter</h2>
            <p class="mt-6 max-w-md text-lg leading-8 text-gray-700">Si vous arriviez ici depuis un ancien lien, une recherche ou un partage, ces acces vous permettront de retrouver rapidement le bon chemin.</p>
          </div>

          <div class="space-y-8">
            <div class="border-t border-primary/10 pt-6">
              <a href="/" class="link-arrow text-lg">
                Accueil
                <LucideIcon name="ArrowRight" class="h-4 w-4" />
              </a>
              <p class="mt-3 text-base leading-7 text-gray-700">Pour reprendre une vue d'ensemble sur le projet, ses actions et ses principales portes d'entree.</p>
            </div>
            <div class="border-t border-primary/10 pt-6">
              <a href="/a-propos-de-nous/" class="link-arrow text-lg">
                A propos de nous
                <LucideIcon name="ArrowRight" class="h-4 w-4" />
              </a>
              <p class="mt-3 text-base leading-7 text-gray-700">Pour comprendre la vision de Pachatopia et le sens general du projet.</p>
            </div>
            <div class="border-t border-primary/10 pt-6">
              <a href="/comment-participer/" class="link-arrow text-lg">
                Soutenir Pachatopia
                <LucideIcon name="ArrowRight" class="h-4 w-4" />
              </a>
              <p class="mt-3 text-base leading-7 text-gray-700">Pour soutenir les actions, participer a la regeneration du territoire ou entrer en contact avec l'association.</p>
            </div>
            <div class="border-t border-primary/10 pt-6">
              <a href="/contacts/" class="link-arrow text-lg">
                Contacts
                <LucideIcon name="ArrowRight" class="h-4 w-4" />
              </a>
              <p class="mt-3 text-base leading-7 text-gray-700">Si vous cherchiez une information precise, nous pouvons vous orienter directement.</p>
            </div>
          </div>
        </div>

        <div class="mt-14 flex flex-wrap justify-center gap-4">
          <a href="/" class="button-primary group">
            Retour a l'accueil
            <LucideIcon name="ArrowRight" class="h-5 w-5 transition-transform duration-300 group-hover:translate-x-1" />
          </a>
          <a href="/contacts/" class="button-secondary">
            Nous contacter
          </a>
        </div>

        <div class="mt-10 text-center">
          <p class="text-sm leading-6 text-gray-500">English speaker? You can also start again from <a href="/en/" class="font-medium text-primary hover:text-accent">the English homepage</a>.</p>
        </div>
      </div>
    </section>
  </main>
  <Footer lang={lang} />
</Layout>
