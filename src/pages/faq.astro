---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import CallToAction from "../components/CallToAction.astro";
import Footer from "../components/Footer.astro";

const lang = "fr";

const faqItems = [
  {
    q: "Qu'est-ce que Pachatopia ?",
    a: "Pachatopia est une association porteuse d'un projet écologique et humain situé dans la région de San Carlos, en Colombie. Notre objectif est de restaurer les écosystèmes, développer une agriculture plus respectueuse de la nature et créer un lieu d'échange autour de la régénération de la Terre.\n\nÀ travers l'agroforesterie, la plantation d'arbres, la création de réserves naturelles et la production de café, nous cherchons à démontrer qu'il est possible de produire tout en régénérant les sols, la biodiversité et les paysages.",
  },
  {
    q: "Comment soutenir le projet ?",
    a: "Vous pouvez soutenir Pachatopia de plusieurs façons :\n• Parrainer un caféier\n• Soutenir la réserve naturelle\n• Acheter le café Pachatopia\n• Faire un don\n• Devenir partenaire du projet",
  },
  {
    q: "Peut-on visiter Pachatopia ?",
    a: "Oui. Pachatopia souhaite devenir un lieu d'accueil pour les personnes qui souhaitent découvrir la nature et les projets de régénération écologique.\n\nÀ terme, il sera possible de séjourner sur place via :\n• Une zone de camping\n• Une auberge de jeunesse\n• Un espace de restauration",
  },
  {
    q: "Comment devenir volontaire ?",
    a: "Nous accueillons des volontaires pour :\n• La plantation d'arbres\n• L'agroforesterie\n• Le travail autour du café\n• L'entretien des parcelles\n\nUne petite participation financière est demandée. En échange, nous proposons :\n• Le logement\n• Un repas par jour\n• Une immersion complète dans le projet",
  },
  {
    q: "Comment acheter le café Pachatopia ?",
    a: "Le café Pachatopia peut être commandé via nos initiatives de soutien au projet.\n\nPour le moment, nous expédions principalement vers :\n• La Colombie\n• La France\n• La Suisse",
  },
  {
    q: "Le café Pachatopia est-il biologique ?",
    a: "Certaines parcelles reprises étaient précédemment cultivées avec des intrants chimiques. Nous avons arrêté ces pratiques et développons désormais des méthodes plus naturelles :\n• Compost\n• Préparations naturelles\n• Diversification des cultures\n• Agroforesterie\n\nNous sommes en transition vers des pratiques entièrement biologiques et régénératives.",
  },
  {
    q: "Où se trouve Pachatopia ?",
    a: "Pachatopia se situe dans la région de San Carlos, département d'Antioquia en Colombie, une région montagneuse riche en biodiversité et engagée dans une dynamique de reconstruction et de régénération.",
  },
  {
    q: "Comment sont organisées les terres de Pachatopia ?",
    a: "Nous réalisons un repérage GPS des différentes parcelles afin de créer une fiche d'identité pour chacune. Cela permet de mieux suivre :\n• Les cultures\n• Les zones de reforestation\n• Les parcelles de café et de cacao\n• Les espaces dédiés à la biodiversité",
  },
];
---

<Layout
  title="FAQ - Pachatopia"
  description="Questions fréquentes sur Pachatopia : soutien, visite, volontariat, café, localisation et organisation des terres."
  lang={lang}
>
  <Header lang={lang} />
  <main>
    <!-- Hero Banner -->
    <section class="relative text-white py-24 md:py-32 overflow-hidden">
      <div class="absolute inset-0">
        <img src="/images/community.jpg" alt="" class="absolute inset-0 w-full h-full object-cover" aria-hidden="true" />
        <div class="absolute inset-0 bg-primary/80"></div>
      </div>
      <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-heading font-bold mb-4">FAQ – Questions fréquentes</h1>
        <p class="text-lg md:text-xl text-white/85">Les réponses essentielles sur le projet Pachatopia</p>
      </div>
      <svg class="absolute bottom-0 left-0 w-full" viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
        <path d="M0 40C240 80 480 0 720 40C960 80 1200 0 1440 40V80H0V40Z" fill="#f8f6f0"/>
      </svg>
    </section>

    <!-- FAQ Accordion -->
    <section class="py-20 md:py-28 bg-cream relative overflow-hidden">
      <div class="absolute top-10 left-10 w-48 h-48 bg-accent/[0.03] rounded-full blur-2xl"></div>
      <div class="absolute bottom-10 right-10 w-64 h-64 bg-primary/[0.03] rounded-full blur-2xl"></div>
      <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="space-y-4">
          {faqItems.map((item, i) => (
            <details class="group bg-white rounded-2xl overflow-hidden" style="box-shadow: 0 2px 8px rgba(11,91,75,0.06);">
              <summary class="flex items-center justify-between cursor-pointer px-6 py-5 md:px-8 md:py-6 list-none [&::-webkit-details-marker]:hidden">
                <div class="flex items-center gap-4">
                  <span class="flex-shrink-0 w-8 h-8 rounded-full bg-golden/15 text-golden-dark flex items-center justify-center text-sm font-semibold">{i + 1}</span>
                  <h3 class="text-primary font-semibold text-base md:text-lg text-left leading-snug pr-4">{item.q}</h3>
                </div>
                <span class="flex-shrink-0 w-8 h-8 rounded-full bg-cream flex items-center justify-center transition-transform duration-300 group-open:rotate-45">
                  <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                  </svg>
                </span>
              </summary>
              <div class="px-6 pb-6 md:px-8 md:pb-8">
                <div class="pl-12 border-l-2 border-golden/30">
                  <p class="text-gray-600 leading-relaxed" style="white-space: pre-line;">{item.a}</p>
                </div>
              </div>
            </details>
          ))}
        </div>

        <div class="mt-12 text-center bg-white rounded-2xl p-8" style="box-shadow: 0 2px 8px rgba(11,91,75,0.06);">
          <p class="text-lg text-gray-700 mb-6">Vous ne trouvez pas la réponse à votre question ? N'hésitez pas à nous contacter.</p>
          <a href="/contacts/" class="inline-flex items-center gap-2 px-8 py-3 bg-golden text-primary font-semibold rounded-full hover:bg-golden-dark transition-colors">Nous contacter</a>
        </div>
      </div>
    </section>
    <CallToAction lang={lang} />
  </main>
  <Footer lang={lang} />
</Layout>
