---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import CallToAction from "../../components/CallToAction.astro";
import Footer from "../../components/Footer.astro";
import LucideIcon from "../../components/LucideIcon.astro";

const lang = "en";

const faqItems = [
  {
    q: "What is Pachatopia?",
    a: "Pachatopia is an association carrying an ecological and human project located in the San Carlos region of Colombia. Our goal is to restore ecosystems, develop more nature-friendly agriculture, and create a place of exchange around Earth regeneration.\n\nThrough agroforestry, tree planting, natural reserve creation, and coffee production, we seek to demonstrate that it is possible to produce while regenerating soils, biodiversity, and landscapes.",
  },
  {
    q: "How can I support the project?",
    a: "You can support Pachatopia in several ways:\n• Sponsor a coffee tree\n• Support the natural reserve\n• Buy Pachatopia coffee\n• Make a donation\n• Become a project partner",
  },
  {
    q: "Can I visit Pachatopia?",
    a: "Yes. Pachatopia aims to become a welcoming place for people who want to discover nature and ecological regeneration projects.\n\nEventually, it will be possible to stay on-site via:\n• A camping area\n• A hostel\n• A dining area",
  },
  {
    q: "How can I volunteer?",
    a: "We welcome volunteers for:\n• Tree planting\n• Agroforestry\n• Coffee-related work\n• Plot maintenance\n\nA small financial contribution is required. In return, we offer:\n• Accommodation\n• One meal per day\n• Full immersion in the project",
  },
  {
    q: "How can I buy Pachatopia coffee?",
    a: "Pachatopia coffee can be ordered through our project support initiatives.\n\nCurrently, we mainly ship to:\n• Colombia\n• France\n• Switzerland",
  },
  {
    q: "Is Pachatopia coffee organic?",
    a: "Some of the plots we took over were previously cultivated with chemical inputs. We have stopped these practices and are now developing more natural methods:\n• Compost\n• Natural preparations\n• Crop diversification\n• Agroforestry\n\nWe are transitioning towards entirely organic and regenerative practices.",
  },
  {
    q: "Where is Pachatopia located?",
    a: "Pachatopia is located in the San Carlos region, Antioquia department in Colombia, a mountainous region rich in biodiversity and engaged in a dynamic of reconstruction and regeneration.",
  },
  {
    q: "How are the Pachatopia lands organized?",
    a: "We carry out GPS mapping of the different plots to create an identity card for each one. This allows us to better track:\n• Crops\n• Reforestation zones\n• Coffee and cacao plots\n• Spaces dedicated to biodiversity",
  },
];
---

<Layout
  title="FAQ - Pachatopia"
  description="Frequently asked questions about Pachatopia: support, visits, volunteering, coffee, location, and land organization."
  lang={lang}
>
  <Header lang={lang} />
  <main>
    <!-- Hero Banner -->
    <section class="relative isolate overflow-hidden py-24 text-white md:py-32">
      <div class="absolute inset-0">
        <img src="/images/community.jpg" alt="FAQ Pachatopia" class="absolute inset-0 w-full h-full object-cover" aria-hidden="true" />
        <div class="absolute inset-0 bg-[linear-gradient(135deg,rgba(8,74,61,0.92),rgba(10,91,75,0.78))]"></div>
      </div>
      <div class="absolute inset-0 -z-0 overflow-hidden" aria-hidden="true">
        <div class="absolute left-[10%] top-12 h-44 w-44 rounded-full bg-white/8 blur-3xl"></div>
        <div class="absolute bottom-0 right-[12%] h-72 w-72 rounded-full bg-golden/15 blur-3xl"></div>
      </div>
      <div class="site-container relative z-10">
        <div class="site-container-compact px-0 text-center">
          <div class="section-kicker mx-auto mb-6 w-fit border-white/15 bg-white/10 text-white shadow-none">
            <LucideIcon name="CircleHelp" class="h-4 w-4 text-golden" />
            FAQ
          </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-heading font-bold mb-4">FAQ – Frequently Asked Questions</h1>
        <p class="text-lg md:text-xl text-white/85">Essential answers about the Pachatopia project</p>
        </div>
      </div>
      <svg class="absolute bottom-0 left-0 w-full" viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
        <path d="M0 40C240 80 480 0 720 40C960 80 1200 0 1440 40V80H0V40Z" fill="#f8f6f0"/>
      </svg>
    </section>

    <!-- FAQ Accordion -->
    <section class="relative isolate overflow-hidden bg-cream py-20 md:py-28">
      <div class="absolute top-10 left-10 w-48 h-48 bg-accent/[0.03] rounded-full blur-2xl"></div>
      <div class="absolute bottom-10 right-10 w-64 h-64 bg-primary/[0.03] rounded-full blur-2xl"></div>
      <div class="site-container relative z-10">
        <div class="grid grid-cols-1 gap-12 lg:grid-cols-[0.8fr_1.2fr] lg:gap-16">
          <div>
            <div class="section-kicker w-fit">
              <LucideIcon name="MessagesSquare" class="h-4 w-4 text-accent" />
              Frequent questions
            </div>
            <h2 class="mt-6 text-3xl font-heading font-bold tracking-tight text-primary md:text-4xl">Everything people ask us most often</h2>
            <p class="mt-6 max-w-md text-lg leading-8 text-gray-700">Whether you want to understand the project, support the actions, visit on-site, or buy the coffee, this page gathers the essential answers in one place.</p>
          </div>

          <div class="space-y-5">
          {faqItems.map((item, i) => (
            <details class:list={[
              "group pt-5",
              i === 0 ? "" : "border-t border-primary/10",
            ]}>
              <summary class="flex items-start justify-between cursor-pointer gap-6 py-2 list-none [&::-webkit-details-marker]:hidden">
                <div class="flex items-center gap-4">
                  <span class="flex-shrink-0 w-8 h-8 rounded-full bg-golden/15 text-golden-dark flex items-center justify-center text-sm font-semibold">{i + 1}</span>
                  <h3 class="text-primary font-semibold text-base md:text-lg text-left leading-snug pr-4">{item.q}</h3>
                </div>
                <span class="flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-full bg-white text-primary transition-transform duration-300 group-open:rotate-45">
                  <LucideIcon name="Plus" class="h-4 w-4" strokeWidth={2.25} />
                </span>
              </summary>
              <div class="pb-6 pl-12 pt-3">
                <div class="border-l border-golden/35 pl-6">
                  <p class="text-gray-600 leading-relaxed" style="white-space: pre-line;">{item.a}</p>
                </div>
              </div>
            </details>
          ))}
          </div>
        </div>
      </div>
    </section>
    <CallToAction lang={lang} />
  </main>
  <Footer lang={lang} />
</Layout>
