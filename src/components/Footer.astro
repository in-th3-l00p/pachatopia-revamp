---
import { useTranslations, getLocalizedPath } from '../i18n/translations';

interface Props {
  lang?: "fr" | "en";
}

const { lang = "fr" } = Astro.props;
const t = useTranslations(lang);

const footerLinks = [
  { label: t("footer.links.discover"), path: "/nos-actions/" },
  { label: t("footer.links.participate"), path: "/venir-sur-place/#volontariat" },
  { label: t("footer.links.support"), path: "/comment-participer/" },
  { label: t("footer.links.contact"), path: "/contacts/" },
];
---

<footer data-testid="footer" class="bg-primary text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 lg:gap-12">

      <!-- Brand Column -->
      <div>
        <a href={getLocalizedPath("/", lang)} class="inline-block mb-4">
          <img src="/images/Logo.png" alt="Pachatopia logo" class="h-12 w-auto" />
        </a>
        <h3 class="font-heading text-2xl font-bold mb-3">Pachatopia</h3>
        <p class="text-white/80 text-sm leading-relaxed mb-2">{t("footer.description")}</p>
        <p class="text-accent text-sm">{t("footer.location")}</p>
      </div>

      <!-- Links Column -->
      <div class="md:justify-self-end">
        <h3 class="text-lg font-heading font-semibold mb-5">
          {t("footer.linksTitle")}
        </h3>
        <nav aria-label={lang === "fr" ? "Liens du pied de page" : "Footer navigation"}>
          <ul class="space-y-2.5">
            {footerLinks.map((link) => (
              <li>
                <a
                  href={getLocalizedPath(link.path, lang)}
                  class="text-white/80 hover:text-accent transition-colors duration-200 text-sm inline-flex items-center gap-2"
                >
                  <svg class="w-3 h-3 text-accent" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                    <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path>
                  </svg>
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>
    </div>
  </div>

  <div class="bg-primary-dark">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <p class="text-center text-white/60 text-xs">
        &copy; 2026 Pachatopia - {t("footer.rights")}
      </p>
    </div>
  </div>
</footer>
