---
import { useTranslations, getLocalizedPath } from '../i18n/translations';

interface Props {
  lang?: "fr" | "en";
}

const { lang = "fr" } = Astro.props;
const t = useTranslations(lang);

const footerLinks = [
  { label: t("footer.discover"), path: "/a-propos-de-nous/" },
  { label: t("footer.participate"), path: "/comment-participer/" },
  { label: t("footer.support"), path: "/le-cafe/" },
  { label: t("footer.contact"), path: "/contacts/" },
];
---

<footer data-testid="footer" class="bg-primary text-white">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 text-center">
    <a href={getLocalizedPath("/", lang)} class="inline-block mb-4">
      <img src="/images/Logo.png" alt="Pachatopia logo" class="h-12 w-auto mx-auto" />
    </a>
    <p class="text-white/80 italic text-sm leading-relaxed mb-2">
      {t("footer.description")}
    </p>
    <p class="text-white/60 text-sm mb-8">
      {t("footer.location")}
    </p>
    <nav aria-label={lang === "fr" ? "Liens du pied de page" : "Footer navigation"}>
      <ul class="flex flex-wrap justify-center gap-6">
        {footerLinks.map((link) => (
          <li>
            <a
              href={getLocalizedPath(link.path, lang)}
              class="text-white/80 hover:text-golden transition-colors duration-200 text-sm font-medium"
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-white/10">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <p class="text-center text-white/50 text-xs">
        &copy; 2026 Pachatopia - {t("footer.rights")} | {lang === "fr" ? "Réalisé par" : "Built by"} <a href="https://tiscacatalin.com" target="_blank" rel="noopener noreferrer" class="text-white/80 hover:text-golden transition-colors duration-200">Cătălin Tișcă</a>
      </p>
    </div>
  </div>
</footer>
